        <mxCell id="a-fast-budget" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#6c8ebf;strokeWidth=1;endArrow=classic;" edge="1" parent="1" source="fastapi" target="dep-budget">
          <mxGeometry relative="1" as="geometry" />

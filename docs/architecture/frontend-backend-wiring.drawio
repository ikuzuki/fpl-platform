        </mxCell>

        <mxCell id="a-fetch-vite" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#4a9999;strokeWidth=2;endArrow=classic;" edge="1" parent="1" source="fetch-call" target="vite-proxy">

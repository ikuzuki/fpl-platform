        <mxCell id="a-lg-lf" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#d6b656;strokeWidth=1;endArrow=classic;dashed=1;" edge="1" parent="1" source="langgraph" target="langfuse">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="a-lg-ddb" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#999999;strokeWidth=1;endArrow=classic;dashed=1;" edge="1" parent="1" source="esr" target="ddb">
          <mxGeometry relative="1" as="geometry">

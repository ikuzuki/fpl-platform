        <mxCell id="a-fast-graph" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#6c8ebf;strokeWidth=1;endArrow=classic;" edge="1" parent="1" source="fastapi" target="dep-graph">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- LangGraph reference -->
        <mxCell id="langgraph" value="&lt;b&gt;LangGraph StateGraph · graph.astream()&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;Planner → Tool Executor → Reflector ⇄ (loop ≤3) → Recommender&lt;br&gt;yields one SSE &quot;step&quot; frame per node, one &quot;result&quot; frame at end&lt;br&gt;&lt;i&gt;internals: see agent-architecture.md&lt;/i&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="440" y="1320" width="620" height="80" as="geometry" />
        </mxCell>

        <mxCell id="a-graph-lg" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#6c8ebf;strokeWidth=2;endArrow=classic;" edge="1" parent="1" source="dep-graph" target="langgraph">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- EventSourceResponse -->
        <mxCell id="esr" value="&lt;b&gt;EventSourceResponse&lt;/b&gt; (sse-starlette)&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;yield _sse(&quot;step&quot;, {&quot;node&quot;: ...})&lt;br&gt;yield _sse(&quot;result&quot;, AgentResponse.model_dump())&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="440" y="1420" width="620" height="55" as="geometry" />
        </mxCell>

        <mxCell id="a-lg-esr" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#6c8ebf;strokeWidth=2;endArrow=classic;" edge="1" parent="1" source="langgraph" target="esr">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ================ BACKING SERVICES ================ -->

        <mxCell id="ddb" value="&lt;b&gt;DynamoDB&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;fpl-agent-usage-dev&lt;br&gt;monthly token spend + cap&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f0f0f0;strokeColor=#999999;fontSize=10;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="150" y="1540" width="200" height="65" as="geometry" />
        </mxCell>

        <mxCell id="neon" value="&lt;b&gt;Neon Postgres + pgvector&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;player_embeddings (384-dim)&lt;br&gt;tools: query_player, search_similar, ...&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f0f0f0;strokeColor=#999999;fontSize=10;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="380" y="1540" width="240" height="65" as="geometry" />
        </mxCell>

        <mxCell id="team-fetcher" value="&lt;b&gt;team-fetcher Lambda&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;boto3.invoke from agent Lambda&lt;br&gt;called by GET /team only&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="650" y="1540" width="220" height="65" as="geometry" />
        </mxCell>

        <mxCell id="langfuse" value="&lt;b&gt;Langfuse (SaaS)&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;@observe traces · session grouping&lt;br&gt;by X-Session-Id · token usage per node&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="900" y="1540" width="240" height="65" as="geometry" />
        </mxCell>

        <mxCell id="secrets" value="&lt;b&gt;Secrets Manager&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;ANTHROPIC_API_KEY, NEON_DATABASE_URL,&lt;br&gt;LANGFUSE_* · fetched at cold-start&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="1170" y="1540" width="230" height="65" as="geometry" />
        </mxCell>

        <!-- Arrows from Lambda to backing services -->
        <mxCell id="a-budget-ddb" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#999999;strokeWidth=1;endArrow=classic;dashed=1;" edge="1" parent="1" source="dep-budget" target="ddb">

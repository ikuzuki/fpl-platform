          <mxPoint x="250" y="1540" as="targetPoint" />
        </mxCell>

        <!-- Secrets cold-start arrow -->
        <mxCell id="a-lwa-secrets" value="cold-start" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#9673a6;strokeWidth=1;endArrow=classic;dashed=1;fontSize=9;fontColor=#a88fa8;" edge="1" parent="1" source="lwa" target="secrets">

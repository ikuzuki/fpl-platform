        <mxCell id="dep-ratelimit" value="&lt;b&gt;Depends: check_rate_limit&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;in-memory sliding window&lt;br&gt;5/min, 20/hr per X-Session-Id&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#eef6ff;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="640" y="1225" width="220" height="55" as="geometry" />

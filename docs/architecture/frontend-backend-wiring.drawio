        <mxCell id="a-fast-rl" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#6c8ebf;strokeWidth=1;endArrow=classic;" edge="1" parent="1" source="fastapi" target="dep-ratelimit">
          <mxGeometry relative="1" as="geometry" />

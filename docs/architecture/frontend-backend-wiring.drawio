        <mxCell id="prod-label" value="&lt;b&gt;PROD — same origin as the SPA&lt;/b&gt;" style="text;html=1;strokeColor=none;fillColor=none;align=center;fontSize=11;fontColor=#999999;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1080" y="335" width="320" height="20" as="geometry" />
        </mxCell>

        <mxCell id="prod-origin" value="&lt;b&gt;Same-origin request&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;page loaded from https://&amp;lt;cloudfront&amp;gt;.cloudfront.net,&lt;br&gt;so /api/agent/chat resolves to that same host&lt;br&gt;— no proxy, no CORS&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d0f0f0;strokeColor=#4a9999;fontSize=10;" vertex="1" parent="1">

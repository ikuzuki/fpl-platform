        <!-- ================ RETURN STREAM ================ -->

        <mxCell id="return-note" value="&lt;b&gt;SSE stream back to the browser&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;Same HTTP response, chunked frames, no buffering at any layer.&lt;br&gt;ChatPanel reducer dispatches STEP per node, then RESULT with the ScoutReport.&lt;br&gt;&lt;i&gt;Break compression=false, break LWA RESPONSE_STREAM, or use API Gateway — stream degrades to one big blob.&lt;/i&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f0fbfb;strokeColor=#4a9999;fontSize=10;align=center;" vertex="1" parent="1">

        <mxCell id="dep-graph" value="&lt;b&gt;Depends: get_graph&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;compiled LangGraph from lifespan&lt;br&gt;(reused across warm invokes)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#eef6ff;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="1130" y="1225" width="220" height="55" as="geometry" />

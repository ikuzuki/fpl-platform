          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="a-cf-data" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#999999;strokeWidth=1;endArrow=classic;dashed=1;" edge="1" parent="1" source="cloudfront" target="cf-data">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="a-cf-agent" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#9673a6;strokeWidth=2;endArrow=classic;" edge="1" parent="1" source="cloudfront" target="cf-agent">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="a-vite-cf" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#4a9999;strokeWidth=2;endArrow=classic;" edge="1" parent="1" source="vite-proxy" target="cloudfront">
          <mxGeometry relative="1" as="geometry">

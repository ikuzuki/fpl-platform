        <mxCell id="a-cfagent-fn" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#9673a6;strokeWidth=2;endArrow=classic;" edge="1" parent="1" source="cf-agent" target="cf-function">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Behavior notes -->
        <mxCell id="cf-notes" value="&lt;b&gt;Agent behaviour settings (critical)&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;&lt;b&gt;• compress = false&lt;/b&gt; — gzip would buffer the SSE stream&lt;br&gt;&lt;b&gt;• CachingDisabled&lt;/b&gt; — POST, per-user responses&lt;br&gt;&lt;b&gt;• AllViewerExceptHostHeader&lt;/b&gt; — forwards X-Session-Id + body&lt;br&gt;&lt;b&gt;• allowed_methods&lt;/b&gt; — includes POST + OPTIONS&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fffef0;strokeColor=#d6b656;fontSize=10;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="1080" y="640" width="320" height="140" as="geometry" />
        </mxCell>

        <mxCell id="adr10-ref" value="&lt;i&gt;see ADR-0010 for the&lt;br&gt;API Gateway → Function URL rationale&lt;/i&gt;" style="text;html=1;strokeColor=none;fillColor=none;align=center;fontSize=9;fontColor=#a88fa8;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="170" y="740" width="280" height="40" as="geometry" />
        </mxCell>

        <mxCell id="auth-gotcha" value="&lt;b&gt;🔒 Function URL is CloudFront-only&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;AuthType=AWS_IAM + Lambda OAC on the origin.&lt;br&gt;CloudFront signs each origin request (SigV4).&lt;br&gt;Resource policy grants invoke only to&lt;br&gt;cloudfront.amazonaws.com scoped by SourceArn.&lt;br&gt;Direct curl to *.lambda-url.* returns 403.&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f0f9f0;strokeColor=#82b366;fontSize=10;align=center;" vertex="1" parent="1">
          <mxGeometry x="170" y="800" width="280" height="90" as="geometry" />
        </mxCell>

        <!-- ================ LAMBDA STAGE ================ -->

        <mxCell id="function-url" value="&lt;b&gt;aws_lambda_function_url&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;invoke_mode = RESPONSE_STREAM&lt;br&gt;authorization_type = AWS_IAM&lt;br&gt;(rejects anything not SigV4-signed by CloudFront)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="580" y="935" width="340" height="65" as="geometry" />

        <!-- Dependency chain -->
        <mxCell id="dep-budget" value="&lt;b&gt;Depends: check_budget&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;DynamoDB GetItem&lt;br&gt;429 if monthly cap hit&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#eef6ff;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="150" y="1225" width="220" height="55" as="geometry" />

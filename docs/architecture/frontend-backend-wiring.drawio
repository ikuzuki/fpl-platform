        <!-- CloudFront Function (path rewrite) -->
        <mxCell id="cf-function" value="&lt;b&gt;CloudFront Function (viewer-request)&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;strips /api/agent prefix:&lt;br&gt;&lt;code&gt;/api/agent/chat&lt;/code&gt; → &lt;code&gt;/chat&lt;/code&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="760" y="740" width="260" height="55" as="geometry" />

          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="lwa" value="&lt;b&gt;AWS Lambda Web Adapter (LWA) sidecar&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;public.ecr.aws/awsguru/aws-lambda-adapter:0.9.0&lt;br&gt;translates RESPONSE_STREAM ↔ local HTTP&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="580" y="1015" width="340" height="60" as="geometry" />
        </mxCell>

        <mxCell id="a-furl-lwa" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#6c8ebf;strokeWidth=2;endArrow=classic;" edge="1" parent="1" source="function-url" target="lwa">

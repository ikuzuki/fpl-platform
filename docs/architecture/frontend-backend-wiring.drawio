        <mxCell id="a-lg-neon" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#999999;strokeWidth=1;endArrow=classic;dashed=1;" edge="1" parent="1" source="langgraph" target="neon">

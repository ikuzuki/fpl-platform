          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ================ EDGE STAGE (CloudFront) ================ -->

        <mxCell id="cloudfront" value="&lt;b&gt;CloudFront Distribution&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;infrastructure/modules/web-hosting/main.tf — path-based routing&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="450" y="570" width="600" height="45" as="geometry" />
        </mxCell>

        <!-- 3 origins -->
        <mxCell id="cf-spa" value="&lt;b&gt;/*  &amp;nbsp; (default)&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;origin: S3 SPA bucket&lt;br&gt;long TTL, invalidated on deploy&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f0f0f0;strokeColor=#999999;fontSize=10;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="180" y="650" width="260" height="60" as="geometry" />
        </mxCell>

        <mxCell id="cf-data" value="&lt;b&gt;/api/v1/*&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;origin: S3 data lake /public/&lt;br&gt;24h TTL&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f0f0f0;strokeColor=#999999;fontSize=10;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="470" y="650" width="260" height="60" as="geometry" />
        </mxCell>

        <mxCell id="cf-agent" value="&lt;b&gt;/api/agent/*&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;origin: Lambda Function URL&lt;br&gt;Lambda OAC (SigV4 signs every origin request)&lt;br&gt;CachingDisabled · AllViewerExceptHostHeader&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="760" y="650" width="260" height="65" as="geometry" />
        </mxCell>


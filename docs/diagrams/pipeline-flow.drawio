        <mxCell id="arrow-checktx-enrich" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#666666;strokeWidth=2;endArrow=classic;" edge="1" parent="1" source="check-transform" target="enrich-parallel">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ============================================================ -->
        <!-- STEP 7: MergeEnrichments                                     -->
        <!-- ============================================================ -->
        <mxCell id="merge" value="&lt;b&gt;MergeEnrichments&lt;/b&gt;&#xa;Lambda" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="720" y="1470" width="160" height="50" as="geometry" />
        </mxCell>
        <mxCell id="arrow-enrich-merge" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#666666;strokeWidth=2;endArrow=classic;" edge="1" parent="1" source="enrich-parallel" target="merge">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- S3 Enriched Layer (final output) -->
        <mxCell id="s3-enriched-final" value="&lt;b&gt;S3 Enriched Layer&lt;/b&gt;&#xa;enriched/player_summaries/season={s}/gameweek={gw}/summaries.parquet&#xa;(all players + enrichment columns for top 300)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f0f0f0;strokeColor=#999999;fontSize=10;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="530" y="1565" width="540" height="50" as="geometry" />
        </mxCell>
        <mxCell id="arrow-merge-s3" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#999999;strokeWidth=2;dashed=1;endArrow=classic;" edge="1" parent="1" source="merge" target="s3-enriched-final">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- CheckEnrichment -->
        <mxCell id="check-enrichment" value="&lt;b&gt;CheckEnrichment&lt;/b&gt;" style="rhombus;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="735" y="1660" width="130" height="60" as="geometry" />
        </mxCell>
        <mxCell id="arrow-s3final-check" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#666666;strokeWidth=2;endArrow=classic;" edge="1" parent="1" source="s3-enriched-final" target="check-enrichment">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ============================================================ -->
        <!-- STEP 8: Terminal states                                      -->
        <!-- ============================================================ -->
        <mxCell id="pipeline-succeeded" value="&lt;b&gt;Pipeline&#xa;Succeeded&lt;/b&gt;" style="ellipse;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="745" y="1780" width="110" height="60" as="geometry" />
        </mxCell>
        <mxCell id="pipeline-failed" value="&lt;b&gt;Pipeline&#xa;Failed&lt;/b&gt;" style="ellipse;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="1100" y="1780" width="110" height="60" as="geometry" />
        </mxCell>
        <mxCell id="arrow-check-success" value="200" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#82b366;strokeWidth=2;endArrow=classic;fontSize=10;fontColor=#666666;" edge="1" parent="1" source="check-enrichment" target="pipeline-succeeded">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Failure arrows (from various checks) -->
        <mxCell id="arrow-checkval-fail" value="invalid" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#b85450;strokeWidth=1;dashed=1;endArrow=classic;fontSize=9;fontColor=#b85450;" edge="1" parent="1" source="check-validation" target="pipeline-failed">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="1155" y="875" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="arrow-checkenrich-fail" value="error" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#b85450;strokeWidth=1;dashed=1;endArrow=classic;fontSize=9;fontColor=#b85450;" edge="1" parent="1" source="check-enrichment" target="pipeline-failed">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ============================================================ -->
        <!-- ANNOTATIONS                                                  -->
        <!-- ============================================================ -->
        <mxCell id="note-filter" value="&lt;i&gt;Top 300 players by ownership&lt;/i&gt;" style="text;html=1;strokeColor=none;fillColor=none;align=center;fontSize=10;fontColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="250" y="1225" width="200" height="20" as="geometry" />
        </mxCell>

        <mxCell id="note-controls" value="&lt;i&gt;Each Lambda: semaphore(2) + rate limiter&lt;/i&gt;" style="text;html=1;strokeColor=none;fillColor=none;align=center;fontSize=10;fontColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="1100" y="1225" width="250" height="20" as="geometry" />
        </mxCell>

        <!-- Downstream consumer hint -->
        <mxCell id="downstream" value="&lt;b&gt;Downstream Consumers&lt;/b&gt;&#xa;Streamlit Dashboard · LangGraph Agent" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="670" y="1880" width="260" height="40" as="geometry" />
        </mxCell>
        <mxCell id="arrow-to-downstream" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#9673a6;strokeWidth=1;dashed=1;endArrow=classic;" edge="1" parent="1" source="pipeline-succeeded" target="downstream">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>

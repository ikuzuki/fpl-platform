# Copy to `.env.development.local` (gitignored) and fill in for local dev.
#
# Vite proxies /api/agent/* to this target so the dashboard at localhost:5173
# can call the agent without CORS preflight. In production CloudFront fronts
# both surfaces same-origin, so this var is dev-only.
VITE_AGENT_PROXY_TARGET=https://dxz2mzo798tf9.cloudfront.net
